         solo_only (bool, optional): If True, recipe cannot run in cluster mode
+        container_name (str, optional): Docker container instance name (default: 'vllm_node').
+            Allows multiple recipes to run simultaneously with distinct names.
+            Must use alphanumeric characters, hyphens, or underscores.
     
     Args:
         recipe_path: Path object pointing to YAML file or just recipe name
@@ -180,7 +186,13 @@ def load_recipe(recipe_path: Path) -> dict[str, Any]:
